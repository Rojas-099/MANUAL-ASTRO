---
import Social from "./social.astro";
---

<footer class="w-full mt-20 bg-[#EFEFF4] border-t-4 border-black py-6 px-4 shadow-[0_-4px_0px_0px_rgba(0,0,0,1)]">
    <div class="w-full flex flex-col items-center justify-center gap-4 text-center">
        
        <p class="font-bold text-black uppercase tracking-wide text-xs">
            © 2026 — Como usar Astro. Hecho por Nicolas Rojas C.
        </p>

        <div class="flex gap-3 justify-center items-center">
            <a href="https://github.com" target="_blank" class="font-black text-xs uppercase tracking-wider text-black bg-white border-2 border-black px-3 py-1 rounded-sm hover:bg-[#A9D6E5] hover:translate-y-[-1px] hover:shadow-[2px_2px_0px_0px_rgba(0,0,0,1)] transition-all duration-150 block">
                GitHub
            </a>
            
        </div>

    </div>
</footer>