---
import BaseLayout from "../layouts/baseLayout.astro"
const allPost = Object.values(import.meta.glob('./posts/*.md',{eager: true}))

const pageTitle = "Mi blog de aprendizaje de Astro ࣪𖤐"
---
<BaseLayout pageTitle = {pageTitle}>
	<h1>{pageTitle}</h1>
	<p>Aqui publicare sobre mi viaje de aprendizaje de Astro</p>
	
	<ul>
		{allPost.map((post: any) => <li><a href={post.url}>{post.frontmatter.title}</a></li>)}
	</ul>
</BaseLayout>