---
import BaseLayout from '../layouts/baseLayout.astro';
import ComoInstalar from '../components/como-instalar.astro';
import ComoIniciar from '../components/como-iniciar.astro';


const postFiles = import.meta.glob("./posts/*.md", { eager: true });
const allPosts = Object.values(postFiles);


const filteredPosts = allPosts.slice(1);
---

<BaseLayout>

    <section class="max-w-4xl mx-auto px-4 py-8 sm:py-12 flex flex-col md:flex-row items-center justify-center gap-6 md:gap-12 text-center md:text-left">
        
        <div class="w-48 sm:w-64 md:w-80 flex-shrink-0">
            <img src="https://i.pinimg.com/736x/2c/d5/0a/2cd50a657b8c059963df0d9f9efe37cc.jpg" alt="Rimuru" class="w-full h-auto object-contain" />
        </div>

        <div class="flex-1 max-w-xl">
            <h1 class="text-2xl sm:text-3xl md:text-4xl font-black text-black uppercase tracking-wide mb-4">
                ¿Qué es ASTRO?
            </h1>
            <p class="font-medium text-gray-700 text-sm sm:text-base leading-relaxed">
                Astro es un framework de desarrollo web diseñado específicamente para sitios web impulsados por contenido, como blogs, sitios de marketing, documentación y e-commerce.
            </p>
        </div>

    </section>


    <ComoInstalar />
    <ComoIniciar />


    

</BaseLayout>